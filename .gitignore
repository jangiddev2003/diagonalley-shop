dist
dist-ssr

# ── Environment variables ────────────────────────────────────────────────────
# NEVER commit real .env files — they contain secrets (DB passwords, JWT keys).
# Each developer/deployment platform creates their own .env from .env.example.
.env
.env.local
.env.production
.env.development
*.env
# Keep the example templates (no real secrets inside)
!.env.example
!server/.env.example

# ── Local dev overrides ──────────────────────────────────────────────────────
*.local

