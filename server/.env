# ============================================
# Diagonalley Shop — Server Environment Variables
# ============================================

# MongoDB connection string
# Replace with your own MongoDB Atlas URI or local MongoDB URI
MONGO_URI=mongodb://127.0.0.1:27017/diagonalley

# JWT secret key — CHANGE THIS in production!
JWT_SECRET=diagonalley_super_secret_spell_key_2026

# JWT token expiration (e.g., 7d = 7 days, 1h = 1 hour)
JWT_EXPIRES_IN=7d

# Server port
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:8080
