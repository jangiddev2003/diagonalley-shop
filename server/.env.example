# ============================================
# Alohomora — Server Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git!

# ── MongoDB ──────────────────────────────────────────────────────────
# Option 1: Local MongoDB (requires MongoDB to be installed and running)
# MONGO_URI=mongodb://127.0.0.1:27017/diagonalley

# Option 2: MongoDB Atlas (recommended — cloud hosted, free tier available)
# Sign up at https://cloud.mongodb.com, create a cluster, then paste the URI below.
# Replace <username>, <password>, and <cluster> with your actual values.
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/diagonalley?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/diagonalley

# ── JWT ───────────────────────────────────────────────────────────────
# CHANGE THIS to a long random string in production!
JWT_SECRET=alohomora_super_secret_spell_key_change_me_in_production
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────
PORT=5000

# ── CORS — Frontend URL ───────────────────────────────────────────────
# In development (Vite dev server):
CLIENT_URL=http://localhost:8080
# In production (replace with your Vercel frontend URL):
# CLIENT_URL=https://your-app.vercel.app
