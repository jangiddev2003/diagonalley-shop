# ============================================
# Diagonalley Shop — Server Environment Variables
# ============================================
# For LOCAL DEV: Copy this file to server/.env and fill in your values.
# For PRODUCTION (Render): Add these as Environment Variables in the Render dashboard.
#                          Do NOT upload a .env file to Render.
# NEVER commit the real .env to git — it contains secrets!

# ── MongoDB Atlas ─────────────────────────────────────────────────────
# Get this from: https://cloud.mongodb.com → Connect → Drivers
# Replace <username>, <password>, and <cluster> with your actual Atlas values.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/diagonalley?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────
# MUST be a long random string in production. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ── Server Port ───────────────────────────────────────────────────────
# Render sets this automatically — do NOT override it in production.
# For local dev, 5000 is the default.
PORT=5000

# ── CORS — Frontend URL ───────────────────────────────────────────────
# LOCAL DEV: Vite dev server (default Vite port)
CLIENT_URL=http://localhost:8080
#
# PRODUCTION: Set this to your exact Vercel URL in the Render dashboard:
# CLIENT_URL=https://diagonalley-shop.vercel.app
